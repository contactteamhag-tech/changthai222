<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Chang Thai Köln – Authentische Thai-Küche in Sülz</title>
  <meta
    name="description"
    content="Chang Thai Köln in Sülz: authentische Thai-Küche, bekannt aus Kabel Eins. Moderne Website mit Speisekarten-Highlights, Auszeichnungen, Kontakt und Bestell-CTA."
  />
  <meta
    name="keywords"
    content="Chang Thai Köln, Thai Restaurant Köln, Sülz, Kabel Eins, Mein Lokal Dein Lokal, Thai Curry Köln, authentische Thai Küche"
  />
  <meta name="theme-color" content="#0f172a" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap"
    rel="stylesheet"
  />

  <style>
    :root{
      --bg:#07111f;
      --bg-2:#0b1728;
      --bg-3:#0f2238;
      --surface:rgba(255,255,255,0.06);
      --surface-strong:rgba(255,255,255,0.09);
      --card:rgba(255,255,255,0.07);
      --line:rgba(255,255,255,0.12);
      --text:#f8fafc;
      --muted:#c9d4e3;
      --soft:#93a5bd;
      --gold:#e7be62;
      --gold-2:#f6d88d;
      --accent:#ff8c42;
      --green:#8fd7b2;
      --shadow:0 20px 60px rgba(0,0,0,0.35);
      --radius:24px;
      --radius-sm:18px;
      --max:1240px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:"Inter",system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at 20% 0%, rgba(231,190,98,0.18), transparent 30%),
        radial-gradient(circle at 100% 10%, rgba(255,140,66,0.16), transparent 28%),
        linear-gradient(180deg, #09111d 0%, #081423 38%, #07111f 100%);
      line-height:1.6;
      overflow-x:hidden;
    }

    body::before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size:40px 40px;
      mask-image:radial-gradient(circle at center, black 42%, transparent 100%);
      opacity:.35;
      z-index:0;
    }

    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}

    .container{
      width:min(var(--max), calc(100% - 40px));
      margin:0 auto;
      position:relative;
      z-index:1;
    }

    .nav-wrap{
      position:sticky;
      top:0;
      z-index:50;
      backdrop-filter:blur(18px);
      background:rgba(7,17,31,0.72);
      border-bottom:1px solid rgba(255,255,255,0.07);
    }

    .nav{
      min-height:78px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:14px;
      min-width:0;
    }

    .brand-mark{
      width:48px;
      height:48px;
      border-radius:14px;
      background:
        linear-gradient(135deg, rgba(231,190,98,0.25), rgba(255,140,66,0.18)),
        rgba(255,255,255,0.08);
      border:1px solid rgba(231,190,98,0.35);
      display:grid;
      place-items:center;
      box-shadow:inset 0 1px 0 rgba(255,255,255,0.2);
      font-weight:900;
      color:var(--gold-2);
      letter-spacing:.04em;
    }

    .brand-text{
      min-width:0;
    }

    .brand-title{
      font-size:1rem;
      font-weight:800;
      letter-spacing:.03em;
      text-transform:uppercase;
    }

    .brand-sub{
      font-size:.84rem;
      color:var(--soft);
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .nav-links{
      display:flex;
      align-items:center;
      gap:10px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .nav-links a{
      padding:10px 14px;
      border-radius:999px;
      color:var(--muted);
      font-weight:600;
      font-size:.95rem;
      transition:.25s ease;
    }

    .nav-links a:hover{
      color:#fff;
      background:rgba(255,255,255,0.06);
    }

    .nav-cta{
      background:linear-gradient(135deg, var(--gold), var(--accent));
      color:#1b1200 !important;
      font-weight:800 !important;
      box-shadow:0 12px 28px rgba(231,190,98,0.22);
    }

    .hero{
      padding:72px 0 34px;
    }

    .hero-grid{
      display:grid;
      grid-template-columns:1.08fr .92fr;
      gap:28px;
      align-items:stretch;
    }

    .hero-copy,
    .hero-card{
      border:1px solid var(--line);
      border-radius:32px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
      box-shadow:var(--shadow);
      position:relative;
      overflow:hidden;
    }

    .hero-copy{
      padding:42px;
    }

    .hero-copy::before,
    .hero-card::before{
      content:"";
      position:absolute;
      inset:-1px;
      background:linear-gradient(135deg, rgba(231,190,98,0.25), transparent 28%, transparent 72%, rgba(255,140,66,0.20));
      pointer-events:none;
      opacity:.9;
    }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:9px 14px;
      border-radius:999px;
      background:rgba(255,255,255,0.07);
      border:1px solid rgba(255,255,255,0.1);
      color:var(--gold-2);
      font-size:.82rem;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      margin-bottom:18px;
    }

    .hero h1{
      margin:0 0 18px;
      font-family:"Playfair Display", serif;
      font-weight:800;
      font-size:clamp(2.6rem, 5vw, 5rem);
      line-height:1.02;
      letter-spacing:-0.03em;
      max-width:11ch;
    }

    .hero h1 span{
      color:var(--gold-2);
    }

    .hero p{
      margin:0 0 28px;
      font-size:1.08rem;
      color:var(--muted);
      max-width:62ch;
    }

    .hero-actions{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
      margin-bottom:28px;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      padding:15px 22px;
      border-radius:999px;
      border:1px solid transparent;
      font-weight:800;
      transition:.25s ease;
      cursor:pointer;
    }

    .btn-primary{
      background:linear-gradient(135deg, var(--gold), var(--accent));
      color:#1d1300;
      box-shadow:0 16px 32px rgba(231,190,98,0.2);
    }

    .btn-primary:hover{
      transform:translateY(-2px);
      box-shadow:0 18px 36px rgba(231,190,98,0.28);
    }

    .btn-secondary{
      background:rgba(255,255,255,0.06);
      border-color:rgba(255,255,255,0.12);
      color:#fff;
    }

    .btn-secondary:hover{
      background:rgba(255,255,255,0.1);
      transform:translateY(-2px);
    }

    .hero-stats{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:14px;
    }

    .stat{
      padding:18px;
      border-radius:20px;
      background:rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.08);
      min-height:110px;
    }

    .stat strong{
      display:block;
      font-size:1.35rem;
      font-weight:900;
      margin-bottom:6px;
      color:#fff;
    }

    .stat span{
      display:block;
      color:var(--soft);
      font-size:.95rem;
    }

    .hero-card{
      padding:26px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      min-height:100%;
    }

    .visual-top{
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:16px;
      margin-bottom:16px;
    }

    .glass,
    .award,
    .dish-highlight,
    .review-box{
      background:rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.1);
      border-radius:24px;
    }

    .glass{
      padding:24px;
      min-height:250px;
      display:flex;
      flex-direction:column;
      justify-content:flex-end;
      background:
        linear-gradient(180deg, rgba(231,190,98,0.09), transparent 40%),
        linear-gradient(160deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
      position:relative;
      overflow:hidden;
    }

    .glass::after{
      content:"";
      position:absolute;
      inset:18px;
      border-radius:22px;
      border:1px solid rgba(231,190,98,0.18);
      pointer-events:none;
    }

    .glass small{
      color:var(--gold-2);
      text-transform:uppercase;
      letter-spacing:.09em;
      font-weight:800;
      font-size:.76rem;
    }

    .glass h3{
      margin:10px 0 10px;
      font-family:"Playfair Display", serif;
      font-size:2rem;
      line-height:1.08;
    }

    .glass p{
      margin:0;
      color:var(--muted);
    }

    .award-stack{
      display:grid;
      gap:16px;
    }

    .award{
      padding:18px;
    }

    .award-tag{
      display:inline-flex;
      padding:8px 12px;
      border-radius:999px;
      background:rgba(231,190,98,0.14);
      color:var(--gold-2);
      font-weight:800;
      font-size:.76rem;
      letter-spacing:.08em;
      text-transform:uppercase;
      margin-bottom:10px;
    }

    .award h4{
      margin:0 0 6px;
      font-size:1rem;
      line-height:1.3;
    }

    .award p{
      margin:0;
      color:var(--soft);
      font-size:.92rem;
    }

    .hero-bottom{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:16px;
    }

    .dish-highlight,
    .review-box{
      padding:18px;
    }

    .label{
      display:inline-block;
      font-size:.76rem;
      letter-spacing:.08em;
      text-transform:uppercase;
      font-weight:800;
      color:var(--gold-2);
      margin-bottom:10px;
    }

    .dish-highlight h4,
    .review-box h4{
      margin:0 0 6px;
      font-size:1.06rem;
    }

    .dish-highlight p,
    .review-box p{
      margin:0;
      color:var(--muted);
      font-size:.95rem;
    }

    .section{
      padding:34px 0;
    }

    .section-head{
      display:flex;
      align-items:end;
      justify-content:space-between;
      gap:20px;
      margin-bottom:24px;
      flex-wrap:wrap;
    }

    .section-kicker{
      color:var(--gold-2);
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      font-size:.78rem;
      margin-bottom:10px;
    }

    .section h2{
      margin:0;
      font-family:"Playfair Display", serif;
      font-size:clamp(2rem, 3.6vw, 3.2rem);
      line-height:1.08;
      letter-spacing:-0.03em;
    }

    .section-head p{
      margin:12px 0 0;
      color:var(--muted);
      max-width:62ch;
    }

    .badges{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:18px;
    }

    .badge-card{
      padding:24px;
      border-radius:26px;
      border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
      box-shadow:var(--shadow);
      position:relative;
      overflow:hidden;
    }

    .badge-card::after{
      content:"";
      position:absolute;
      inset:auto -40px -50px auto;
      width:160px;
      height:160px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(231,190,98,0.18), transparent 70%);
      pointer-events:none;
    }

    .badge-icon{
      width:58px;
      height:58px;
      border-radius:18px;
      display:grid;
      place-items:center;
      margin-bottom:18px;
      background:linear-gradient(135deg, rgba(231,190,98,0.22), rgba(255,140,66,0.14));
      border:1px solid rgba(231,190,98,0.24);
      font-size:1.25rem;
      font-weight:900;
      color:var(--gold-2);
    }

    .badge-card h3{
      margin:0 0 10px;
      font-size:1.15rem;
    }

    .badge-card p{
      margin:0;
      color:var(--muted);
    }

    .story-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:20px;
    }

    .story-card{
      padding:26px;
      border-radius:28px;
      border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,0.07), rgba(255,255,255,0.04));
      box-shadow:var(--shadow);
    }

    .story-card h3{
      margin:0 0 12px;
      font-size:1.2rem;
    }

    .story-card p{
      margin:0 0 14px;
      color:var(--muted);
    }

    .info-list{
      display:grid;
      gap:12px;
      margin-top:18px;
    }

    .info-item{
      display:flex;
      gap:12px;
      align-items:flex-start;
      padding:12px 14px;
      background:rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.08);
      border-radius:16px;
    }

    .info-item strong{
      display:block;
      margin-bottom:2px;
      font-size:.96rem;
    }

    .info-item span{
      color:var(--soft);
      font-size:.94rem;
    }

    .menu-grid{
      display:grid;
      grid-template-columns:repeat(4, minmax(0,1fr));
      gap:18px;
    }

    .menu-card{
      padding:22px;
      border-radius:24px;
      border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
      box-shadow:var(--shadow);
      display:flex;
      flex-direction:column;
      min-height:240px;
    }

    .menu-top{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      margin-bottom:16px;
    }

    .menu-tag{
      display:inline-flex;
      padding:8px 10px;
      border-radius:999px;
      background:rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.09);
      color:var(--gold-2);
      font-size:.75rem;
      text-transform:uppercase;
      letter-spacing:.08em;
      font-weight:800;
    }

    .price{
      font-size:1.15rem;
      font-weight:900;
      white-space:nowrap;
      color:#fff;
    }

    .menu-card h3{
      margin:0 0 8px;
      font-size:1.15rem;
    }

    .menu-card p{
      margin:0;
      color:var(--muted);
      font-size:.95rem;
    }

    .menu-card .meta{
      margin-top:auto;
      padding-top:18px;
      color:var(--soft);
      font-size:.88rem;
    }

    .usp-grid{
      display:grid;
      grid-template-columns:repeat(4, minmax(0,1fr));
      gap:18px;
    }

    .usp{
      padding:22px;
      border-radius:22px;
      border:1px solid var(--line);
      background:rgba(255,255,255,0.06);
    }

    .usp strong{
      display:block;
      font-size:1.05rem;
      margin-bottom:8px;
    }

    .usp p{
      margin:0;
      color:var(--muted);
      font-size:.95rem;
    }

    .cta{
      padding:10px 0 56px;
    }

    .cta-box{
      padding:34px;
      border-radius:32px;
      border:1px solid rgba(231,190,98,0.22);
      background:
        radial-gradient(circle at top right, rgba(231,190,98,0.18), transparent 28%),
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
      box-shadow:var(--shadow);
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:22px;
      align-items:center;
    }

    .cta-box h2{
      margin:0 0 10px;
      font-family:"Playfair Display", serif;
      font-size:clamp(2rem, 3.6vw, 3rem);
      line-height:1.08;
    }

    .cta-box p{
      margin:0;
      color:var(--muted);
      max-width:56ch;
    }

    .cta-panel{
      display:grid;
      gap:12px;
    }

    .cta-card{
      padding:16px 18px;
      border-radius:18px;
      background:rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.1);
    }

    .cta-card strong{
      display:block;
      margin-bottom:4px;
    }

    .cta-card span{
      color:var(--soft);
      font-size:.94rem;
    }

    footer{
      padding:24px 0 54px;
      color:var(--soft);
      font-size:.92rem;
    }

    .footer-wrap{
      border-top:1px solid rgba(255,255,255,0.08);
      padding-top:18px;
      display:flex;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
    }

    .muted-note{
      font-size:.86rem;
      color:#8ea0b8;
    }

    @media (max-width: 1120px){
      .hero-grid,
      .story-grid,
      .cta-box{
        grid-template-columns:1fr;
      }

      .menu-grid{
        grid-template-columns:repeat(2, minmax(0,1fr));
      }

      .usp-grid,
      .badges{
        grid-template-columns:repeat(2, minmax(0,1fr));
      }
    }

    @media (max-width: 760px){
      .container{width:min(var(--max), calc(100% - 22px))}
      .nav{padding:12px 0}
      .nav-links{display:none}
      .hero{padding-top:36px}
      .hero-copy,
      .hero-card,
      .story-card,
      .cta-box{padding:22px}
      .hero-stats,
      .hero-bottom,
      .visual-top,
      .badges,
      .usp-grid,
      .menu-grid{
        grid-template-columns:1fr;
      }
      .hero h1{max-width:100%}
      .stat{min-height:auto}
      .section{padding:26px 0}
    }
  </style>
</head>
<body>

  <div class="nav-wrap">
    <div class="container nav">
      <a href="#top" class="brand" aria-label="Chang Thai Startseite">
        <div class="brand-mark">CT</div>
        <div class="brand-text">
          <div class="brand-title">Chang Thai Köln</div>
